{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://openrisk.platform/schemas/plugin-manifest/0.0.1.json",
    "title": "OpenRisk Plugin Manifest",
    "description": "Schema for OpenRisk plugin manifest (plugin.json)",
    "type": "object",
    "required": [
        "id",
        "version",
        "name",
        "description",
        "authors",
        "license",
        "main",
        "entrypoints"
    ],
    "properties": {
        "id": {
            "type": "string",
            "description": "Stable plugin identifier used in project database",
            "pattern": "^[a-z][a-z0-9_-]{0,63}$"
        },
        "$schema": {
            "type": "string",
            "description": "JSON Schema reference for IDE support"
        },
        "entrypoints": {
            "type": "array",
            "description": "Named entrypoints exposed by the plugin. At least one named entrypoint is required.",
            "minItems": 1,
            "items": {
                "$ref": "#/definitions/PluginEntrypointDefinition"
            }
        },
        "version": {
            "type": "string",
            "description": "Plugin version in semver format (e.g., 0.1.0)",
            "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-((?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*)(?:\\.(?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*))*))?(?:\\+([0-9a-zA-Z-]+(?:\\.[0-9a-zA-Z-]+)*))?$"
        },
        "name": {
            "type": "string",
            "description": "Human-readable plugin name",
            "minLength": 1,
            "maxLength": 255
        },
        "description": {
            "type": "string",
            "description": "Brief description of plugin functionality",
            "minLength": 1,
            "maxLength": 1000
        },
        "authors": {
            "type": "array",
            "description": "List of plugin authors",
            "minItems": 1,
            "items": {
                "type": "object",
                "required": [
                    "name"
                ],
                "properties": {
                    "name": {
                        "type": "string",
                        "description": "Author name"
                    },
                    "email": {
                        "type": "string",
                        "description": "Author email address",
                        "format": "email"
                    },
                    "url": {
                        "type": "string",
                        "description": "Author website",
                        "format": "uri"
                    }
                },
                "additionalProperties": false
            }
        },
        "icon": {
            "type": "string",
            "description": "Path to plugin icon (relative to plugin directory)",
            "pattern": "^[^/].*\\.(png|svg|jpg|jpeg)$"
        },
        "license": {
            "type": "string",
            "description": "SPDX license identifier (e.g., MIT, Apache-2.0, GPL-3.0)",
            "minLength": 1
        },
        "main": {
            "type": "string",
            "description": "Main TypeScript/JavaScript file (relative to plugin directory)",
            "pattern": "^[^/].*\\.(ts|js)$"
        },
        "update_metrics_fn": {
            "type": "string",
            "description": "Optional function name to call for refreshing declared metrics in settings.",
            "pattern": "^[a-zA-Z_$][a-zA-Z0-9_$]*$"
        },
        "settings": {
            "type": "array",
            "description": "Plugin configuration settings",
            "items": {
                "$ref": "#/definitions/SettingDefinition"
            }
        },
        "metrics": {
            "type": "array",
            "description": "Runtime metrics emitted by plugin code through openrisk.metrics.* receiver.",
            "items": {
                "$ref": "#/definitions/MetricDefinition"
            }
        },
        "repository": {
            "type": "string",
            "description": "Plugin source code repository URL",
            "format": "uri"
        },
        "homepage": {
            "type": "string",
            "description": "Plugin homepage URL",
            "format": "uri"
        },
        "keywords": {
            "type": "array",
            "description": "Plugin keywords for searchability",
            "items": {
                "type": "string"
            }
        }
    },
    "additionalProperties": false,
    "definitions": {
        "PluginEntrypointDefinition": {
            "description": "A named entrypoint exposed by a plugin.",
            "type": "object",
            "required": [
                "id",
                "name",
                "function",
                "inputs"
            ],
            "properties": {
                "id": {
                    "type": "string",
                    "description": "Stable entrypoint identifier (kebab-case)",
                    "pattern": "^[a-z][a-z0-9_-]*$"
                },
                "name": {
                    "type": "string",
                    "description": "Human-readable entrypoint name",
                    "minLength": 1
                },
                "description": {
                    "type": "string",
                    "description": "Entrypoint description"
                },
                "function": {
                    "type": "string",
                    "description": "Named export function in the entrypoint file",
                    "pattern": "^[a-zA-Z_$][a-zA-Z0-9_$]*$"
                },
                "inputs": {
                    "type": "array",
                    "description": "Entrypoint-specific input parameters.",
                    "items": {
                        "$ref": "#/definitions/InputDefinition"
                    }
                }
            },
            "additionalProperties": false
        },
        "ValidationRules": {
            "type": "object",
            "description": "Additional validation rules (legacy fallback for enum).",
            "properties": {
                "enum": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "description": "Allowed values for enum-like fields."
                }
            },
            "additionalProperties": false
        },
        "FieldType": {
            "description": "Input/setting type: shorthand string or detailed object.",
            "oneOf": [
                {
                    "type": "string",
                    "enum": [
                        "string",
                        "number",
                        "boolean",
                        "integer",
                        "date",
                        "url"
                    ]
                },
                {
                    "type": "object",
                    "required": [
                        "name"
                    ],
                    "properties": {
                        "name": {
                            "type": "string",
                            "enum": [
                                "string",
                                "number",
                                "boolean",
                                "integer",
                                "date",
                                "url",
                                "enum"
                            ]
                        },
                        "values": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            },
                            "description": "Enum values when name='enum'."
                        }
                    },
                    "additionalProperties": false
                }
            ]
        },
        "InputDefinition": {
            "type": "object",
            "required": [
                "name",
                "type",
                "title"
            ],
            "properties": {
                "name": {
                    "type": "string",
                    "description": "Input parameter name (can use *args or **kwargs syntax)",
                    "pattern": "^(\\*{0,2}[a-z][a-z0-9_]*)$"
                },
                "type": {
                    "$ref": "#/definitions/FieldType"
                },
                "optional": {
                    "type": "boolean",
                    "description": "Whether this input is optional",
                    "default": false
                },
                "title": {
                    "type": "string",
                    "description": "Human-readable input name"
                },
                "description": {
                    "type": "string",
                    "description": "Detailed input description"
                },
                "default": {
                    "description": "Default value for optional inputs"
                },
                "validation": {
                    "$ref": "#/definitions/ValidationRules"
                }
            },
            "additionalProperties": false
        },
        "SettingDefinition": {
            "type": "object",
            "required": [
                "name",
                "type",
                "title"
            ],
            "properties": {
                "name": {
                    "type": "string",
                    "description": "Setting identifier (snake_case)",
                    "pattern": "^[a-z][a-z0-9_]*$"
                },
                "type": {
                    "$ref": "#/definitions/FieldType"
                },
                "title": {
                    "type": "string",
                    "description": "Human-readable setting name"
                },
                "description": {
                    "type": "string",
                    "description": "Detailed setting description"
                },
                "default": {
                    "description": "Default value for the setting (null allowed)"
                },
                "required": {
                    "type": "boolean",
                    "description": "Whether this setting is required",
                    "default": false
                },
                "validation": {
                    "$ref": "#/definitions/ValidationRules"
                }
            },
            "additionalProperties": false
        },
        "MetricDefinition": {
            "type": "object",
            "required": [
                "name",
                "type",
                "title"
            ],
            "properties": {
                "name": {
                    "type": "string",
                    "description": "Metric key used by openrisk.metrics.set/get/inc",
                    "pattern": "^[a-z][a-z0-9_]{1,63}$"
                },
                "type": {
                    "$ref": "#/definitions/FieldType"
                },
                "title": {
                    "type": "string",
                    "description": "Human-readable metric name"
                },
                "description": {
                    "type": "string",
                    "description": "Metric purpose shown in UI"
                }
            },
            "additionalProperties": false
        }
    }
}