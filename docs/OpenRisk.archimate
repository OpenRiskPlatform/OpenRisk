    <element xsi:type="archimate:ApplicationComponent" name="Audit Logger" id="id-d5eed5b0273544639cb568714845766e"/>
    <element xsi:type="archimate:ApplicationComponent" name="Report Generator" id="id-fc701050985e4d8f8a0a6d686a1ab398"/>
    <element xsi:type="archimate:DataObject" name="Project" id="id-3eeaf97a4e334c88bf9910c3cbb135bb"/>
    <element xsi:type="archimate:DataObject" name="Scan" id="id-a537fba76ed544659221dbc1e5cbacad"/>
    <element xsi:type="archimate:DataObject" name="Audit Log" id="id-86258255030e492e816c7bb21ce6cc14"/>
    <element xsi:type="archimate:DataObject" name="Report" id="id-9cdb7f1057d74ae6ab7ec6b23d2795f4"/>
    <element xsi:type="archimate:ApplicationComponent" name="Plugin" id="id-77fc5e5a83ef40e897038bffb1c96e92">
      <documentation>loaded plugin&#xD;
&#xD;
do not confuse with Plugin Package&#xD;
Plugin - is loaded code with access to network, fs, JS runtime&#xD;
Plugin package is just data</documentation>
    </element>
    <element xsi:type="archimate:ApplicationComponent" name="Plugin Manager" id="id-ebe13ff86bc04edbb4bd5f111d9ade06"/>
    <element xsi:type="archimate:ApplicationComponent" name="Project Manager" id="id-949c531ff5424ed9bcb4cdb8562a647e">
      <documentation>Manages selected plugins, scans, projects, settings</documentation>
    </element>
    <element xsi:type="archimate:DataObject" name="Plugin Package" id="id-32596d7d79024c5dbc1a198d40a2b836">
      <documentation>code + manifest&#xD;
&#xD;
do not confuse with Plugin &#xD;
Plugin - is loaded code with access to network, fs, JS runtime&#xD;
Plugin package is just data</documentation>
    </element>
  </folder>
  <folder name="Technology &amp; Physical" id="id-5dde5b35d81e4a6aa2f33ba4506d359d" type="technology"/>
  <folder name="Motivation" id="id-5f5ec4f167444fefae5cb16d7676aac0" type="motivation">
    <element xsi:type="archimate:Stakeholder" name="Investigator" id="id-66a3d4dbd46e4eb6b558a80c4dcd5c4e">
      <documentation>Due diligence team/person responsible for investigation process inside the Organization&#xD;
Our primary user of the desktop application</documentation>
    </element>
    <element xsi:type="archimate:Driver" name="Audit obligations" id="id-193471a397934b8c877034c49760eba8">
      <documentation>!!! TODO
Add more info</documentation>
    </element>
    <element xsi:type="archimate:Driver" name="Manual overhead" id="id-8a4953c38e604825bc80532d1b572855">
      <documentation>Manual checks are too slow and inconsistent, and may have human factor mistakes</documentation>
    </element>
    <element xsi:type="archimate:Driver" name="УСПЕВАТЬ К New Data Sources appear" id="id-00b465702f4d430bb6ec5181ff1e2a05">
      <documentation>New adata sources appear aften, so we need quick extensibility</documentation>
    </element>
    <element xsi:type="archimate:Principle" name="Local-first" id="id-2cd543331d8244e1823266bce4e55796">
      <documentation>Data must be local to avoid problems with storage and access to data (problems with regulations, etc.).</documentation>
    </element>
    <element xsi:type="archimate:Constraint" name="Desktop context" id="id-4a02e5d08de44ba090f6ad828bb2aee8">
      <documentation>Our software will be executed on desktop platform, with all the consequences</documentation>
    </element>
    <element xsi:type="archimate:Stakeholder" name="Auditor" id="id-d93f63ed58a0459891804a1cd2fbdbf6">
      <documentation>Official who verifies due diligence&#xD;
Does not belong to the Customer Organization&#xD;
</documentation>
    </element>
    <element xsi:type="archimate:Stakeholder" name="Research Subject" id="id-2c03b5b016534a6f86d145f78f4b34f2">
      <documentation>A person or any entity that will be subject to a background check</documentation>
    </element>
    <element xsi:type="archimate:Principle" name="Best effort privacy" id="id-087b687ebd0c468188274d7ec0ff36ab">
      <documentation>Data can't be accessed by unauthorized third parties</documentation>
    </element>
    <element xsi:type="archimate:Principle" name="Open-source" id="id-2af8db292f504b6a9d8a3c52e97c26c4">
      <documentation>It means that the whole codebase should be open source, and developers can contribute to and extend it</documentation>
    </element>
    <element xsi:type="archimate:Stakeholder" name="Plugin developer" id="id-fedddfd0b89b45208e26264025b06048">
      <documentation>Anyone who creates plugins for the application&#xD;
</documentation>
    </element>
    <element xsi:type="archimate:Constraint" name="Third‑party plugin security not guaranteed" id="id-8c517b52722f4301925eda56b3a3c0f4">
      <documentation>We cannot assume plugin third-party authors will follow secure coding practices</documentation>
    </element>
    <element xsi:type="archimate:Requirement" name="Public SDK, templates, and documentation for plugins" id="id-5aa2bacd6c194c0398e184a015bca19c">
      <documentation>The platform must enable plugin developers of varied experience levels to build correct plugins with minimal guidance.</documentation>
    </element>
    <element xsi:type="archimate:Requirement" name="Controlled plugin runtime" id="id-37235204e2504d46b11c406b8ef3944b"/>
    <element xsi:type="archimate:Goal" name="Plugin-based extensibility" id="id-85b5ca4e5dd74a7588fc25cf166cf89c"/>
    <element xsi:type="archimate:Goal" name="Convenient Investigation Process" id="id-f72406e0b93f46ff8f351f38add16643"/>
    <element xsi:type="archimate:Goal" name="Audit trails" id="id-b8f8f8997ad843268a16df4d8c8cce77"/>
    <element xsi:type="archimate:Requirement" name="Audit trail capture" id="id-e310a51199ae47539041e672923ecb4c"/>
    <element xsi:type="archimate:Assessment" name="Investigation accesses sensitive information" id="id-f44f63349be642aaad9ab55ba75a1e09"/>
    <element xsi:type="archimate:Driver" name="Privacy expectations" id="id-f9497ee7485a41719af582c395dc8e28"/>
    <element xsi:type="archimate:Driver" name="Ecosystem incentives" id="id-9900a228f25248bbb6d3101b44a66a18">
      <documentation>basically money or reputation&#xD;
For plugin developer its reputation of open source contributors. Or they can create their own paid plugins.&#xD;
For Data Providers integration in the form of a plugin increases their user base.&#xD;
&#xD;
> For plugin developer its reputation of open source contributors. &#xD;
Саня сказал что єто хуйня</documentation>
    </element>
    <element xsi:type="archimate:Requirement" name="Plugin registry" id="id-2eec59695ee64321885bc38695c43fe3">
      <documentation>Plugin store should help users and plugin developers find exising plugins  in the store. Store also </documentation>
    </element>
    <element xsi:type="archimate:Stakeholder" name="Data Source" id="id-777e99a30f484b0da9c5b5830c08cd7e"/>
    <element xsi:type="archimate:Assessment" name="Current solutions usually integrate with one Data Source" id="id-6afa24cdeb524623b34951b0c2493df2"/>
    <element xsi:type="archimate:Assessment" name="Audits require evidence trails" id="id-b8ae652088284e3abbd6d61f2e955d90"/>
    <element xsi:type="archimate:Assessment" name="Manual investigations are long and hard" id="id-a61b733dfbd04018bbd6524c9bbdd45f"/>
    <element xsi:type="archimate:Assessment" name="New relevant Data Sources will be created" id="id-77bf4f02c2804ea683c23faa53d06e24"/>
    <element xsi:type="archimate:Requirement" name="Full-text search" id="id-b47d0b9f993e4af6abfa18c496c2df97">
      <documentation>Find specific scan in project&#xD;
</documentation>
    </element>
    <element xsi:type="archimate:Requirement" name="Project sharing" id="id-d05446c101fb4b628eae57bd0438a706"/>
    <element xsi:type="archimate:Requirement" name="Project management" id="id-84b9e267d13048a88d91d0e9326d7312">
      <documentation>project includes many scans&#xD;
this is useful when company wants to have one domain/topic configured, operated and stored in one entity&#xD;
( folders with settings  :)  )</documentation>
    </element>
    <element xsi:type="archimate:Requirement" name="Cross-platform native desktop application support" id="id-6e0ffb77853c4d6085cfc2fb42d65528">
      <documentation>Windows and MacOS required&#xD;
Linux optional</documentation>
    </element>
    <element xsi:type="archimate:Stakeholder" name="Customer" id="id-e34de1195e354fc0b4c682a479adb6c4"/>
    <element xsi:type="archimate:Constraint" name="Plugins can access network and filesystem" id="id-c8a48bf0233c4c2db9541cc8d8118b6e"/>
    <element xsi:type="archimate:Driver" name="Broad desktop adoption" id="id-d9d1b4fe0c1041f3b6ad89e7c1916fbd"/>
    <element xsi:type="archimate:Assessment" name="Customer organizations use a mix of Windows and macOS devices" id="id-dc95d8d4a8a44403b2efd7746e907550"/>
    <element xsi:type="archimate:Goal" name="OS-independent usage" id="id-28c7ca98a3074cbfb44c8f7953758f88"/>
    <element xsi:type="archimate:Assessment" name="Ability to write custom plugins for money or reputation makes for a better product" id="id-f02e1e84c6f34e73ae84e4924999cbca"/>
    <element xsi:type="archimate:Requirement" name="Interractive UI" id="id-36dcaa7d768647f69a66394185ac29d7"/>
    <element xsi:type="archimate:Assessment" name="Current solutions are proprietary" id="id-2d5e1d3fe8e84593972004cb7742bc7d"/>
    <element xsi:type="archimate:Assessment" name="Centralized data storage in web applications is easily compromisable" id="id-1c70caded37440369f3fa8df9649cbbd"/>
  </folder>
