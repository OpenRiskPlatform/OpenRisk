  <folder name="Business" id="id-0ce05f883c6640f484bcdc7281ad8805" type="business">
    <element xsi:type="archimate:BusinessRole" name="Investigator" id="id-f8c4a3534cea4db1aff436e698f3f149"/>
    <element xsi:type="archimate:BusinessRole" name="Auditor" id="id-3fc1f84cc2b24aaf8a6cf21b6e399129"/>
    <element xsi:type="archimate:BusinessRole" name="Plugin Developer" id="id-9e5c122494b74e809682d22abf16f2da"/>
