    <element xsi:type="archimate:BusinessObject" name="Scan" id="id-3a897b760fe245aa9ea6139a90cd6623"/>
    <element xsi:type="archimate:BusinessObject" name="Scan Result" id="id-ef235e5fd5de44a19c82ce70f2ea775d"/>
    <element xsi:type="archimate:BusinessObject" name="Report" id="id-0958132ff2b34520bbac573378d5df6b"/>
    <element xsi:type="archimate:BusinessObject" name="Scan Audit" id="id-c145a1de1b6f4216a6c3588f6826e472">
      <documentation>Logs of all plugin executions and their related netword, fs accesses</documentation>
    </element>
    <element xsi:type="archimate:BusinessObject" name="Plugin" id="id-94a653997451468984774cd702d49371"/>
    <element xsi:type="archimate:BusinessObject" name="Plugin Settings" id="id-b20518d2990240dbb72ba27e8c50ba98"/>
    <element xsi:type="archimate:BusinessService" name="Investigation Service" id="id-f9599c153bc74ccebea7de05c8a63989"/>
    <element xsi:type="archimate:BusinessService" name="Audit Evidence Service" id="id-29db41bf69814d2493acaa0fb189b024"/>
    <element xsi:type="archimate:BusinessService" name="Plugin Marketplace Service" id="id-75828edc74144244b7735628734163b6">
      <documentation>This can be any plugin marketplace, initially it will be only our marketplace be we will allow to install plugins from external marketplaces</documentation>
    </element>
    <element xsi:type="archimate:BusinessFunction" id="id-1c77f3a3eba44edf957abbe01c167b68"/>
    <element xsi:type="archimate:BusinessProcess" name="Create Project" id="id-43ea864057844593a5818479d7e5ccd3"/>
    <element xsi:type="archimate:BusinessProcess" name="Manage Plugins" id="id-f36c994475044446a27bd87b916dc773">
      <documentation>download, configure, uninstall plugins for the project</documentation>
    </element>
    <element xsi:type="archimate:BusinessProcess" name="Run Scan" id="id-563e1c67de4344e7acf5fab41050ca16">
      <documentation>execute all selected plugins </documentation>
    </element>
    <element xsi:type="archimate:BusinessProcess" name="Review Results" id="id-6822e08e1526470d87e23d9805f703b4">
      <documentation>view results in UI</documentation>
    </element>
    <element xsi:type="archimate:BusinessObject" name="Scan Inputs" id="id-ab405db495f64ee4900f8cfe495503df"/>
    <element xsi:type="archimate:BusinessProcess" name="Create Scan" id="id-03a3f5a13dcf4bf198c16c632d68f653"/>
    <element xsi:type="archimate:BusinessProcess" name="Configure Scan" id="id-ebea4d1488cb401da5d09c0601a302b4">
      <documentation>change plugin settings for this scan</documentation>
    </element>
    <element xsi:type="archimate:BusinessProcess" name="Enter Inputs" id="id-816190950590436d9504f9443d6b7455">
      <documentation>when plugins are configures - user sees auto-generated input form that they enter inputs into</documentation>
    </element>
    <element xsi:type="archimate:BusinessProcess" name="Export Report" id="id-b302165d0a2d4a73bc5d43d86d66f4d6">
      <documentation>Create Report that can be XLSX, CSV, PDF, or any other &#xD;
</documentation>
    </element>
    <element xsi:type="archimate:BusinessProcess" name="Develop Plugin" id="id-331bfb31dd0e4aa4a466c559a41cb649">
      <documentation>Create plugin using our SDK and templates</documentation>
    </element>
    <element xsi:type="archimate:BusinessProcess" name="Publish Plugin" id="id-fc25d516877a4d019b0afcbece595820">
      <documentation>push plugin to any marketplace</documentation>
    </element>
    <element xsi:type="archimate:BusinessProcess" name="Investigate Further" id="id-03e09c95e36e4649a1e3d5c154bd5cff">
      <documentation>create new scan using old scan (if there is need for extra investigate for this specific Research Subject)&#xD;
Scans are immutable so in order to add new info to the scan you create new scan and inherit old one</documentation>
    </element>
    <element xsi:type="archimate:BusinessProcess" name="Review Scan Audit" id="id-d36f7922392e444fa5dc178fb2b4f12a">
      <documentation>View Scan with it's results and it's audit logs to verigy that investigator actually conducted investigation&#xD;
</documentation>
    </element>
    <element xsi:type="archimate:BusinessProcess" name="Investigations" id="id-79a44eec48674c90ade1b4978f656416"/>
    <element xsi:type="archimate:BusinessProcess" name="Plugin Development" id="id-088e6f26006141fdbb45d52b0bcdc114"/>
    <element xsi:type="archimate:BusinessProcess" name="Maintain Plugin" id="id-f2eb7c4a7cda49d692c3daa7d47f6f34">
      <documentation>push new version of the plugin to the marketplace</documentation>
    </element>
    <element xsi:type="archimate:BusinessObject" name="Plugin SDK/Template" id="id-970e993d1c794e3f9719202527d1df27"/>
  </folder>
  <folder name="Application" id="id-8b834064aeb14ade987e07fb0e243438" type="application">
